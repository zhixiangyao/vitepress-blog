{
  "name": "vitepress-blog",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Blog",
  "author": "zhixiangyao <blueskyzx@icloud.com> <https://github.com/zhixiangyao>",
  "homepage": "https://github.com/zhixiangyao/vitepress-blog",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhixiangyao/vitepress-blog.git"
  },
  "keywords": [
    "zhixiangyao",
    "blog",
    "vitepress",
    "vue",
    "pnpm",
    "monorepo"
  ],
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "dev": "pnpm --filter blog dev",
    "build": "pnpm --filter blog build",
    "preview": "pnpm --filter blog preview",
    "------- 🌕 FORMAT -------": "",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/",
    "lint:css": "stylelint --fix \"./**/*.{vue,postcss,css}\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "lint-staged": "catalog:",
    "medium-zoom": "catalog:",
    "postcss": "catalog:",
    "postcss-html": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-recommended-vue": "catalog:",
    "stylelint-config-standard": "catalog:",
    "stylelint-order": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitepress": "catalog:",
    "vue": "catalog:"
  },
  "lint-staged": {
    "*": [
      "eslint --cache --cache-location node_modules/.cache/eslint/"
    ],
    "./**/*.{vue,postcss,css}": [
      "npx stylelint --fix --cache --cache-location node_modules/.cache/stylelint/"
    ]
  }
}
