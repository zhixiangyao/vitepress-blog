{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "types": ["node", "vitepress/client"],
    "skipLibCheck": true,
    "rootDir": "./docs/.vitepress",
  },
  "include": ["/**/*.ts", "docs/.vitepress/**/*.d.ts", "docs/.vitepress/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}
