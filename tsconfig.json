{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2020", "dom"],
    "types": ["node", "vitepress/client"],
    "skipLibCheck": true,
    "rootDir": "./docs/.vitepress",
  },
  "include": ["docs/.vitepress/**/*.ts", "docs/.vitepress/**/*.d.ts", "docs/.vitepress/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}
